# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Encontre em: https://aistudio.google.com/app/apikey
# Usado para: transcrição de voz e geração de planejamento (server-side apenas)
GEMINI_API_KEY=AIza...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Encontre em: https://platform.openai.com/api-keys
# Usado para: transcrição de voz (Whisper) e extração de imagens (GPT-4o)
OPENAI_API_KEY=sk-...

# ── Google Calendar (OAuth2) ──────────────────────────────────────────────────
# Criar em: https://console.cloud.google.com → APIs & Services → Credentials
# 1. Ative a "Google Calendar API" no projeto
# 2. Crie uma credencial "OAuth 2.0 Client ID" do tipo "Web application"
# 3. Adicione o URI de redirecionamento autorizado abaixo
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI de redirecionamento — deve ser exatamente o mesmo configurado no Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/auth/callback
# URL pública da aplicação (usada para montar redirects após OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Evolution API (WhatsApp Bot) ──────────────────────────────────────────────
# URL da instância — sem barra no final
EVOLUTION_API_URL=https://evolution-api-production-f64d.up.railway.app
# Chave de autenticação da sua instância Evolution API
EVOLUTION_API_KEY=sua_chave_evolution_api
# Nome da instância Evolution API (ex: dentai-clinica)
EVOLUTION_DEFAULT_INSTANCE=sua_instancia
# UUID da clínica padrão — obtido no Supabase → tabela clinicas
EVOLUTION_DEFAULT_CLINICA_ID=uuid-da-clinica
# Segredo aleatório para proteger o endpoint de cron de lembretes
CRON_SECRET=gere-um-uuid-aleatorio
